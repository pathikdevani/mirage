{
  "name": "mirage",
  "private": true,
  "version": "0.0.0",
  "description": "Mirage — web-UI-driven fake data generation tool.",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "nx": "nx",
    "dev": "nx run-many -t serve --parallel=10",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "gen:openapi": "pnpm --filter @mirage/types run gen",
    "postinstall": "pnpm --filter @mirage/types run gen",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "nx": "^20.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
