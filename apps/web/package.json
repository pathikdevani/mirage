{
  "name": "@mirage/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@mirage/types": "workspace:*",
    "@mirage/ui-kit": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-query": "^5.62.16",
    "lucide-react": "^0.471.1",
    "monaco-editor": "^0.52.2",
    "oidc-client-ts": "^3.1.0",
    "openapi-fetch": "^0.13.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7"
  },
  "nx": {
    "name": "@mirage/web",
    "targets": {
      "serve": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vite",
          "cwd": "apps/web"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vite build",
          "cwd": "apps/web"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p tsconfig.json --noEmit",
          "cwd": "apps/web"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint src",
          "cwd": "apps/web"
        }
      }
    }
  }
}
