{
  "name": "@mirage/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./fastify": "./src/fastify-plugin.ts"
  },
  "dependencies": {
    "@mirage/types": "workspace:*",
    "fastify-plugin": "^5.0.1",
    "jose": "^5.9.6"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  },
  "nx": {
    "name": "@mirage/auth",
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p tsconfig.json --noEmit",
          "cwd": "packages/auth"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint src",
          "cwd": "packages/auth"
        }
      }
    }
  }
}
