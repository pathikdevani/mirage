{
  "name": "@mirage/sandbox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts"
  },
  "dependencies": {
    "@faker-js/faker": "9.3.0",
    "@mirage/types": "workspace:*"
  },
  "nx": {
    "name": "@mirage/sandbox",
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p tsconfig.json --noEmit",
          "cwd": "packages/sandbox"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint src",
          "cwd": "packages/sandbox"
        }
      }
    }
  }
}
