{
  "name": "@mirage/fakerjs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@faker-js/faker": "9.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "generate": "node scripts/generate-registry.mjs",
    "test": "vitest run"
  },
  "nx": {
    "name": "@mirage/fakerjs",
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p tsconfig.json --noEmit",
          "cwd": "packages/fakerjs"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint src",
          "cwd": "packages/fakerjs"
        }
      },
      "generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node scripts/generate-registry.mjs",
          "cwd": "packages/fakerjs"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run",
          "cwd": "packages/fakerjs"
        }
      }
    }
  }
}
