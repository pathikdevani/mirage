{
  "name": "@mirage/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^9.3.0",
    "@mirage/sandbox": "workspace:*",
    "@mirage/types": "workspace:*"
  },
  "nx": {
    "name": "@mirage/engine",
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -p tsconfig.json --noEmit",
          "cwd": "packages/engine"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint src",
          "cwd": "packages/engine"
        }
      }
    }
  }
}
