# Mirage — environment template.
# Copy to `.env` at the repo root (or per-app under `apps/<app>/.env`) and adjust as needed.
# Values below match the defaults in `infra/docker-compose.yml`.

# ---------- MongoDB ----------
MONGO_URL=mongodb://mirage:mirage@localhost:27017/mirage?authSource=admin
MONGO_DB=mirage

# ---------- Redis (BullMQ + pub/sub) ----------
REDIS_URL=redis://localhost:6379

# ---------- Object storage (MinIO, S3-compatible) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=miragedev
S3_SECRET_KEY=miragedev-secret
S3_BUCKET=mirage
S3_FORCE_PATH_STYLE=true

# ---------- Keycloak (OIDC) ----------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=mirage
# Issuer used by JWT verifiers
KEYCLOAK_ISSUER=http://localhost:8080/realms/mirage
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/mirage/protocol/openid-connect/certs

# Public SPA client (PKCE, no secret)
KEYCLOAK_CLIENT_ID_WEB=mirage-web

# Confidential BFF client (service-account flow)
KEYCLOAK_CLIENT_ID_BFF=mirage-bff
KEYCLOAK_CLIENT_SECRET_BFF=dev-bff-secret-change-me

# ---------- Mail (MailHog, dev only) ----------
SMTP_HOST=localhost
SMTP_PORT=1025

# ---------- App ports (host) ----------
WEB_PORT=5173
BFF_PORT=4000
WORKSPACE_SVC_PORT=4001
EXPORT_SVC_PORT=4002

# ---------- BFF runtime ----------
BFF_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:5173

# ---------- Logging ----------
LOG_LEVEL=info
NODE_ENV=development
